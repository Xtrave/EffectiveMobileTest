<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.EffectiveMobileTest" parent="Theme.Material3.DynamicColors.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/green</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/green</item>
        <item name="colorSecondaryContainer">@color/light_gray</item>
        <item name="colorOnSecondaryContainer">@color/green</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/dark</item>

        <item name="colorSurfaceContainerLowest">@color/dark</item>
        <item name="colorSurfaceContainer">@color/dark_gray</item>

        <item name="colorOnSurface">@color/green</item>
        <item name="colorOnSurfaceVariant">@color/white</item>
    </style>
</resources>
